@startuml UC10 – Gérer l'espace compte (Diagramme de Séquence Système)

skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam sequenceParticipantBorderColor #6FA8DC
skinparam sequenceParticipantBackgroundColor #CFE2F3
skinparam sequenceActorBorderColor #6FA8DC
skinparam sequenceActorBackgroundColor #CFE2F3
skinparam sequenceLifeLineBorderColor #6FA8DC
skinparam SequenceGroupBorderColor #6FA8DC
skinparam SequenceGroupBackgroundColor #E8F0FB
skinparam SequenceGroupBodyBackgroundColor #FFFFFF

title interaction Gérer l'espace compte

actor "Utilisateur: Actor1" as U
participant "Système" as S

ref over U, S : (S'authentifier)

U -> S : 1 : Accéder à "Mon Compte"
S --> U : 2 : Afficher les informations personnelles\net les réservations

alt [modifier les informations personnelles]
    U -> S : 3 : Modifier les informations et valider
    S -> S : 4 : Mettre à jour le profil
    S --> U : 5 : Afficher message "Profil mis à jour avec succès"

else [changer le mot de passe]
    U -> S : 3 : Saisir l'ancien et le nouveau mot de passe
    S -> S : 4 : Vérifier l'ancien mot de passe

    alt [mot de passe incorrect]
        S --> U : 5 : Afficher message d'erreur
    else [mot de passe correct]
        S -> S : 6 : Enregistrer le nouveau mot de passe
        S --> U : 7 : Afficher message de confirmation
    end

else [supprimer le compte]
    U -> S : 3 : Demander la suppression du compte
    S --> U : 4 : Afficher une demande de confirmation

    alt [annuler]
        S --> U : 5 : Rester sur la page compte
    else [confirmer]
        S -> S : 6 : Supprimer le compte
        S --> U : 7 : Déconnecter et rediriger vers la page d'accueil
    end
end

@enduml
