@startuml UC7a – A3 : Consulter l'historique des transactions (Diagramme de Séquence)

skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam sequenceParticipantBorderColor #6FA8DC
skinparam sequenceParticipantBackgroundColor #CFE2F3
skinparam sequenceActorBorderColor #6FA8DC
skinparam sequenceActorBackgroundColor #CFE2F3
skinparam sequenceLifeLineBorderColor #6FA8DC
skinparam SequenceGroupBorderColor #6FA8DC
skinparam SequenceGroupBackgroundColor #E8F0FB
skinparam SequenceGroupBodyBackgroundColor #FFFFFF

title A3 : Consulter l'historique des transactions

actor "Utilisateur: Actor1" as U
participant "Système" as S

U -> S : 1 : Consulter la section "Historique des points"
S -> S : 2 : Récupérer les transactions de l'utilisateur

alt [historique vide]
    S --> U : 3 : Afficher "Aucun historique pour le moment."
else [historique non vide]
    S --> U : 4 : Afficher la liste chronologique des transactions
    note right
    Pour chaque transaction :
    - Description
    - Date et heure
    - Points (+/-)
    - Icône (+/-)
    end note
end

@enduml